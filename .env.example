# PostgreSQL
POSTGRES_PASSWORD=change-me-strong-postgres-password

# Redis
REDIS_PASSWORD=change-me-redis-password

# JWT — must be identical for ApiIdentity (issuer) and ApiCore (validator)
# Key must be at least 32 characters long
JWT_KEY=change-me-to-a-very-long-random-secret-key-32-chars-min
JWT_ISSUER=http://192.168.15.106
JWT_AUDIENCE=http://192.168.15.106

# Port the Web app will be exposed on the host
WEB_PORT=8081

# Aspire Dashboard token (used to log in at http://<host>:18888)
DASHBOARD_TOKEN=change-me-dashboard-secret-token
