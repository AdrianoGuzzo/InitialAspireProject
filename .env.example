# PostgreSQL
POSTGRES_PASSWORD=change-me-strong-postgres-password

# Redis
REDIS_PASSWORD=change-me-redis-password

# JWT — must be identical for ApiIdentity (issuer) and ApiCore (validator)
# Key must be at least 32 characters long
JWT_KEY=change-me-to-a-very-long-random-secret-key-32-chars-min
JWT_ISSUER=http://192.168.15.106
JWT_AUDIENCE=http://192.168.15.106

# Port the Web app will be exposed on the host
WEB_PORT=8081

# Aspire Dashboard token (used to log in at http://<host>:18888)
DASHBOARD_TOKEN=change-me-dashboard-secret-token

# Base URL of the web frontend (used to build password-reset links)
APP_BASE_URL=http://192.168.15.106:8081

# SMTP — configure a real mail server for password-reset emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_SSL=false
SMTP_FROM_ADDRESS=noreply@example.com
SMTP_FROM_NAME=Initial Aspire Project
SMTP_USERNAME=seuemail@gmail.com
SMTP_PASSWORD=sua_app_password

# Google OAuth — create credentials at https://console.cloud.google.com/
# Authorized redirect URI must include: https://<your-domain>/signin-google
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Internal API key — shared secret between Web and ApiIdentity for Google SSO
# Generate a strong random value (e.g. openssl rand -hex 32)
INTERNAL_API_KEY=change-me-to-a-strong-random-secret
