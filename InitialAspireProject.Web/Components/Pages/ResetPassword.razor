@page "/reset-password"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout Layout.EmptyLayout
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.WebUtilities
@using InitialAspireProject.Web.Services
@inject IResetPasswordService ResetPasswordService
@inject NavigationManager NavigationManager

<div class="container-fluid vh-100">
	<div class="row h-100">
		<!-- Left Side - Branding -->
		<div class="col-lg-6 d-none d-lg-flex bg-primary text-white align-items-center justify-content-center auth-branding">
			<div class="text-center p-5">
				<i class="bi bi-rocket-takeoff display-1 mb-4"></i>
				<h1 class="display-4 fw-bold mb-4">Initial Aspire Project</h1>
				<p class="lead mb-4">
					@L["ResetPasswordBrandingText"]
				</p>
				<div class="row text-center mt-5">
					<div class="col-4">
						<i class="bi bi-shield-check display-6 mb-2"></i>
						<div class="small">@L["Secure"]</div>
					</div>
					<div class="col-4">
						<i class="bi bi-lightning-fill display-6 mb-2"></i>
						<div class="small">@L["Fast"]</div>
					</div>
					<div class="col-4">
						<i class="bi bi-palette-fill display-6 mb-2"></i>
						<div class="small">@L["Modern"]</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Right Side - Form -->
		<div class="col-lg-6 d-flex align-items-center justify-content-center">
			<div class="w-100" style="max-width: 450px;">
				<div class="card shadow-lg border-0 auth-card">
					<div class="card-header bg-white text-center py-4">
						<div class="d-lg-none mb-3">
							<i class="bi bi-rocket-takeoff text-primary display-4"></i>
						</div>
						<h2 class="h3 fw-bold text-dark mb-1">@L["ResetPasswordTitle"]</h2>
						<p class="text-muted mb-0">@L["ResetPasswordSubtitle"]</p>
					</div>

					<div class="card-body p-4">
						@if (invalidLink)
						{
							<div class="alert alert-danger d-flex align-items-center" role="alert">
								<i class="bi bi-exclamation-triangle-fill me-2"></i>
								<div>@L["InvalidResetLink"]</div>
							</div>
						}
						else if (success)
						{
							<div class="alert alert-success d-flex align-items-center" role="alert">
								<i class="bi bi-check-circle-fill me-2"></i>
								<div>@L["PasswordResetSuccessMsg"]</div>
							</div>
							<div class="d-grid mt-3">
								<a href="/login" class="btn btn-primary btn-lg">
									<i class="bi bi-box-arrow-in-right me-2"></i>
									@L["Login"]
								</a>
							</div>
						}
						else
						{
							@if (!string.IsNullOrEmpty(errorMessage))
							{
								<div class="alert alert-danger d-flex align-items-center" role="alert">
									<i class="bi bi-exclamation-triangle-fill me-2"></i>
									<div>@errorMessage</div>
								</div>
							}

							<EditForm Model="formModel" OnValidSubmit="HandleSubmit" FormName="ResetPasswordForm">
								<DataAnnotationsValidator />

								<div class="mb-3">
									<label for="newPassword" class="form-label fw-semibold">
										<i class="bi bi-lock me-1"></i>
										@L["NewPassword"]
									</label>
									<div class="input-group">
										<InputText id="newPassword" type="password"
												   class="form-control form-control-lg"
												   @bind-Value="formModel!.NewPassword"
												   placeholder="@L["NewPasswordPlaceholder"]" />
										<button class="btn btn-outline-secondary" type="button"
												onclick="togglePasswordVisibility('newPassword', this)">
											<i class="bi bi-eye"></i>
										</button>
									</div>
									<div class="form-text small">
										<i class="bi bi-info-circle me-1"></i>
										@L["PasswordHint8"]
									</div>
									<ValidationMessage For="@(() => formModel.NewPassword)" class="text-danger small mt-1" />
								</div>

								<div class="mb-3">
									<label for="confirmPassword" class="form-label fw-semibold">
										<i class="bi bi-lock-fill me-1"></i>
										@L["ConfirmNewPassword"]
									</label>
									<div class="input-group">
										<InputText id="confirmPassword" type="password"
												   class="form-control form-control-lg"
												   @bind-Value="formModel!.ConfirmPassword"
												   placeholder="@L["ConfirmNewPasswordPlaceholder"]" />
										<button class="btn btn-outline-secondary" type="button"
												onclick="togglePasswordVisibility('confirmPassword', this)">
											<i class="bi bi-eye"></i>
										</button>
									</div>
									<ValidationMessage For="@(() => formModel.ConfirmPassword)" class="text-danger small mt-1" />
								</div>

								<div class="d-grid mb-3">
									<button type="submit" class="btn btn-primary btn-lg" disabled="@isLoading">
										@if (isLoading)
										{
											<span class="spinner-border spinner-border-sm me-2" role="status"></span>
											<span>@L["Resetting"]</span>
										}
										else
										{
											<i class="bi bi-check-circle me-2"></i>
											<span>@L["ResetPasswordTitle"]</span>
										}
									</button>
								</div>
							</EditForm>
						}
					</div>

					<div class="card-footer bg-light text-center py-3">
						<p class="mb-0 text-muted">
							<a href="/login" class="text-decoration-none fw-semibold">
								<i class="bi bi-box-arrow-in-right me-1"></i>
								@L["BackToLogin"]
							</a>
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

@code {
	[SupplyParameterFromForm(FormName = "ResetPasswordForm")]
	private ResetPasswordFormModel? formModel { get; set; }

	private string? email;
	private string? token;
	private bool invalidLink = false;
	private bool success = false;
	private bool isLoading = false;
	private string? errorMessage;
	protected override void OnInitialized()
	{
		formModel ??= new();

		var uri = new Uri(NavigationManager.Uri);
		var query = QueryHelpers.ParseQuery(uri.Query);

		query.TryGetValue("email", out var emailValue);
		query.TryGetValue("token", out var tokenValue);

		email = emailValue.ToString();
		token = tokenValue.ToString();

		if (string.IsNullOrEmpty(email) || string.IsNullOrEmpty(token))
			invalidLink = true;
	}

	private async Task HandleSubmit()
	{
		if (string.IsNullOrEmpty(email) || string.IsNullOrEmpty(token)) return;

		isLoading = true;
		errorMessage = null;
		try
		{
			var result = await ResetPasswordService.ResetPasswordAsync(email, token, formModel!.NewPassword, formModel.ConfirmPassword);
			if (result.Success)
				success = true;
			else
				errorMessage = result.Message;
		}
		finally
		{
			isLoading = false;
		}
	}

	public class ResetPasswordFormModel
	{
		[Required(ErrorMessageResourceType = typeof(WebMessages), ErrorMessageResourceName = "NewPasswordRequired")]
		[MinLength(8, ErrorMessageResourceType = typeof(WebMessages), ErrorMessageResourceName = "PasswordMin8")]
		public string NewPassword { get; set; } = string.Empty;

		[Required(ErrorMessageResourceType = typeof(WebMessages), ErrorMessageResourceName = "ConfirmPasswordRequired")]
		[Compare(nameof(NewPassword), ErrorMessageResourceType = typeof(WebMessages), ErrorMessageResourceName = "PasswordMismatch")]
		public string ConfirmPassword { get; set; } = string.Empty;
	}
}
